---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(articles.flatMap(a => a.data.tags || []))].sort();
---

<BaseLayout title="文章">
  <Header />
  <main class="page-main">
    <div class="container">
      <div class="page-header reveal">
        <h1>文章</h1>
        <p>技术分享、开发心得、效率思考</p>
      </div>

      {articles.length > 0 ? (
        <section class="section section-compact">
          <div class="tag-filter reveal">
            <button class="tag-pill active" data-tag="all" aria-pressed="true">全部</button>
            {allTags.map(tag => (
              <button class="tag-pill" data-tag={tag} aria-pressed="false">{tag}</button>
            ))}
          </div>
          <div class="articles-grid" id="articles-grid">
            {articles.map(article => (
              <a
                href={`/articles/${article.slug}/`}
                class="tilt-card article-card reveal"
                data-tags={JSON.stringify(article.data.tags || [])}
              >
                {article.data.tags && (
                  <div class="a-tags">
                    {article.data.tags.map(tag => (
                      <span>{tag}</span>
                    ))}
                  </div>
                )}
                <h3>{article.data.title}</h3>
                <p class="excerpt">{article.data.summary}</p>
                <div class="a-meta">
                  <span class="date">
                    {article.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                  </span>
                  <span class="more">阅读全文 &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      ) : (
        <p class="empty-state">还没有文章，敬请期待</p>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  function initArticlesPage(): void {
    const pills = document.querySelectorAll('.tag-pill');
    const cards = document.querySelectorAll<HTMLElement>('#articles-grid .article-card');
    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => {
          p.classList.remove('active');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('active');
        pill.setAttribute('aria-pressed', 'true');
        const tag = (pill as HTMLElement).dataset.tag;
        cards.forEach(card => {
          const tags = JSON.parse(card.dataset.tags || '[]');
          const show = tag === 'all' || tags.includes(tag);
          card.style.display = show ? '' : 'none';
          if (show) {
            card.style.opacity = '0';
            card.style.transform = 'translateY(12px)';
            requestAnimationFrame(() => {
              card.style.transition = 'opacity 0.4s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1)';
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            });
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initArticlesPage);
</script>
