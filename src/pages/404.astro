---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404">
  <Header />
  <main class="page-main">
    <div class="not-found">
      <div class="terminal-window not-found-terminal">
        <div class="terminal-chrome">
          <span class="terminal-dot dot-red"></span>
          <span class="terminal-dot dot-yellow"></span>
          <span class="terminal-dot dot-green"></span>
          <span class="terminal-title">zsh — 404</span>
        </div>
        <div class="terminal-body not-found-body">
          <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">cd {Astro.url.pathname}</span></div>
          <div class="terminal-line"><span class="t-error">zsh: no such file or directory: {Astro.url.pathname}</span></div>
          <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">pwd</span></div>
          <div class="terminal-line"><span class="t-output t-dim">/home/visitor/site/404</span></div>
          <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">echo "你迷路了"</span></div>
          <div class="terminal-line"><span class="t-output">你迷路了，这里什么都没有。</span></div>
          <div class="terminal-line" style="margin-top: 8px"><span class="t-dim"># 也许你想回到 <a href="/" style="color:#7aa2f7">首页</a>，或者 <a href="/articles/" style="color:#7aa2f7">看看文章</a></span></div>
          <div class="terminal-line" style="margin-top: 8px"><span class="t-prompt">$</span> <span class="t-cursor">_</span></div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .not-found {
    display: flex; align-items: center; justify-content: center;
    min-height: 60vh;
    padding: 40px 20px;
  }
  .not-found-terminal {
    max-width: 480px;
    width: 100%;
    margin-bottom: 0;
  }
  .not-found-body {
    max-height: none;
    overflow: visible;
  }
</style>
