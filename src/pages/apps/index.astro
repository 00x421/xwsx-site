---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const apps = (await getCollection('apps'))
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<BaseLayout title="应用">
  <Header />
  <main class="page-main">
    <div class="container">
      <div class="page-header reveal">
        <h1>应用</h1>
        <p>我自己开发的小工具和应用</p>
      </div>

      {apps.length > 0 ? (
        <section class="section section-compact">
          <div class="apps-grid reveal">
            {apps.map(app => (
              <a href={`/apps/${app.slug}/`} class="app-card">
                <div class="app-card-icon">{app.data.icon || '📦'}</div>
                <div class="app-card-info">
                  <div class="app-card-top">
                    <h3>{app.data.name}</h3>
                    <span class="app-ver">v{app.data.version}</span>
                  </div>
                  <p class="app-card-desc">{app.data.summary}</p>
                  <div class="app-card-bottom">
                    <div class="app-platforms">
                      {app.data.platforms.map(p => (
                        <span>{p}</span>
                      ))}
                    </div>
                    <span class="app-card-arrow">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="list-end reveal">
            <p>有想做的工具？欢迎交流 →</p>
          </div>
        </section>
      ) : (
        <p class="empty-state">还没有发布的应用，开发中</p>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
