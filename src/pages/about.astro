---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import nowData from '../data/now.json';
---

<BaseLayout title="关于">
  <Header />
  <main class="page-main">
    <div class="container">
      <div class="page-header reveal">
        <h1>关于</h1>
      </div>
      <div class="about-page">
        <div class="about-section reveal">
          <h3>👋 你好，我是烦恼全無先生</h3>
          <p>一个热爱折腾的独立开发者 / 全栈工程师。白天写业务代码，晚上做自己的产品。相信好的工具可以改变人的工作方式。</p>
          <p>这个网站是我的数字花园，记录技术思考、开发心得，以及我做的那些小工具。</p>
        </div>

        <div class="about-section reveal reveal-d1">
          <h3>📍 此刻 <span class="now-updated">更新于 {nowData.updated}</span></h3>
          <div class="now-timeline">
            {nowData.items.map((item: { label: string; value: string }) => (
              <div class="now-item">
                <span class="now-label">{item.label}</span>
                <span class="now-value">{item.value}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="about-section reveal reveal-d2">
          <h3>🛠 技术栈</h3>
          <div class="about-tags">
            <span>TypeScript</span>
            <span>React</span>
            <span>Node.js</span>
            <span>Python</span>
            <span>Astro</span>
            <span>Rust</span>
            <span>Tauri</span>
          </div>
        </div>

        <div class="about-section reveal reveal-d3">
          <h3>📝 关于这个网站</h3>
          <p>本站使用 <strong>Astro</strong> 构建，采用静态站点生成方案。内容通过 Markdown 管理。</p>
          <p>雾蓝灰莫兰迪配色，精致利落的动效，追求现代极简的阅读体验。</p>
        </div>

        <div class="about-section about-connect reveal">
          <h3>🔗 找到我</h3>
          <div class="connect-links">
            <a href="https://github.com/" target="_blank" rel="noopener" class="connect-card">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              <div>
                <span class="connect-name">GitHub</span>
                <span class="connect-desc">开源项目和代码</span>
              </div>
            </a>
            <a href="mailto:hello@example.com" class="connect-card">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
              <div>
                <span class="connect-name">邮件</span>
                <span class="connect-desc">hello@example.com</span>
              </div>
            </a>
            <a href="/articles/" class="connect-card">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
              <div>
                <span class="connect-name">文章</span>
                <span class="connect-desc">技术分享和开发心得</span>
              </div>
            </a>
            <a href="/apps/" class="connect-card">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              <div>
                <span class="connect-name">应用</span>
                <span class="connect-desc">我开发的小工具</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
