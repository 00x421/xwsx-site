---
import '../styles/hero.css';
---

{/* Three.js Canvas — hidden on tier-3 (mobile) */}
<canvas id="scene3d" role="img" aria-label="3D 空间漫游背景"></canvas>

{/* CSS Fallback for mobile / low-end devices */}
<div class="hero-fallback" id="heroFallback" style="display:none">
  <p class="fb-greeting" id="fbGreeting"></p>
  <p class="fb-sub">Hello, I'm</p>
  <div class="fb-name">烦恼全<span class="char-outline">無</span>先生</div>
  <p class="fb-desc">独立开发者 / 全栈工程师 · 专注效率工具与优雅数字产品</p>
  <div class="fb-tags">
    <span class="fb-tag">全栈开发</span>
    <span class="fb-tag">独立开发</span>
    <span class="fb-tag">效率工具</span>
    <span class="fb-tag">开源</span>
  </div>
  <div class="fb-btns">
    <a href="/articles/" class="fb-btn">文章 →</a>
    <a href="/apps/" class="fb-btn">应用 →</a>
    <a href="/about/" class="fb-btn">关于 →</a>
  </div>
</div>

{/* HTML Text Overlay (3D mode only) */}
<div class="hero-overlay" id="heroOverlay">
  <p class="h3d-el h3d-greeting" id="h3dGreeting" data-pos="0,1.8,0"></p>
  <p class="h3d-el h3d-sub" data-pos="0,1.3,0.4">Hello, I'm</p>
  <div class="h3d-el h3d-chars" id="h3dChars" data-pos="0,0.3,-0.2">
    <div class="char-wrap" data-idx="0"><span class="char-el">烦</span></div>
    <div class="char-wrap" data-idx="1"><span class="char-el">恼</span></div>
    <div class="char-wrap" data-idx="2"><span class="char-el">全</span></div>
    <div class="char-wrap" data-idx="3"><span class="char-el char-outline">無</span></div>
    <div class="char-wrap" data-idx="4"><span class="char-el">先</span></div>
    <div class="char-wrap" data-idx="5"><span class="char-el">生</span></div>
  </div>
  <p class="h3d-el h3d-desc" id="h3dDesc" data-pos="0,-0.6,0.4" data-typewriter="独立开发者 / 全栈工程师 · 专注效率工具与优雅数字产品">
    <span id="h3dType"></span><span class="h3d-cursor"></span>
  </p>
  <div class="h3d-el h3d-tags" data-pos="0,-1.3,0.8">
    <span class="h3d-tag">全栈开发</span>
    <span class="h3d-tag">独立开发</span>
    <span class="h3d-tag">效率工具</span>
    <span class="h3d-tag">开源</span>
  </div>
  <div class="h3d-el h3d-btns" data-pos="0,-2.1,0.4">
    <a href="/articles/" class="h3d-btn">文章 →</a>
    <a href="/apps/" class="h3d-btn">应用 →</a>
    <a href="/about/" class="h3d-btn">关于 →</a>
  </div>
  <div class="h3d-el h3d-clock" id="h3dClock" data-pos="0,-2.9,1.2">--:--:--</div>
</div>

{/* Transparent lens */}
<div class="lens" id="lens">
  <div class="lens-content">
    <div class="lens-t1" id="lt1">你好</div>
    <div class="lens-t2" id="lt2">全無先生</div>
    <div class="lens-sub" id="ls">Welcome</div>
  </div>
</div>

{/* Drag hint */}
<div class="drag-hint" id="dragHint">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10" opacity=".3"/><path d="M8 12l4-4 4 4M12 8v8"/></svg>
  <span>拖动探索空间</span>
</div>

{/* Reset view */}
<button class="reset-view" id="resetView" title="重置视角">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
</button>

{/* Overlays */}
<div class="vignette-overlay"></div>
<div class="grain-overlay"></div>

<script>
  import { detectTier } from '../scripts/hero/detect';
  import { createScene } from '../scripts/hero/scene';
  import { createControls } from '../scripts/hero/controls';
  import { createAnimator } from '../scripts/hero/animate';
  import { initUI } from '../scripts/hero/ui';
  import { createProjection, collectTextNodes } from '../scripts/hero/projection';

  document.body.style.overflow = 'hidden';

  const tier = detectTier();

  // Tier-3: show CSS fallback, skip Three.js
  if (tier === 3) {
    const fallback = document.getElementById('heroFallback')!;
    fallback.style.display = 'flex';
    document.getElementById('scene3d')!.style.display = 'none';
    document.getElementById('heroOverlay')!.style.display = 'none';
    document.getElementById('lens')!.style.display = 'none';
    document.getElementById('dragHint')!.style.display = 'none';
    document.getElementById('resetView')!.style.display = 'none';

    // Greeting for fallback
    const h = new Date().getHours();
    const fbGreeting = document.getElementById('fbGreeting');
    if (fbGreeting) {
      fbGreeting.textContent =
        h >= 5 && h < 12 ? '早上好' :
        h >= 12 && h < 18 ? '下午好' :
        h >= 18 && h < 22 ? '晚上好' :
        '夜深了，注意休息';
    }
  } else {
    // Tier-1 or Tier-2: full 3D scene
    const canvas = document.getElementById('scene3d') as HTMLCanvasElement;
    const resetBtn = document.getElementById('resetView');
    const dragHint = document.getElementById('dragHint');

    const sd = createScene(canvas, tier);
    const controls = createControls(sd.camera, resetBtn, dragHint);

    const textNodes = collectTextNodes();
    const projection = createProjection(sd.camera, textNodes);

    const charWraps = document.querySelectorAll<HTMLElement>('.char-wrap');

    const ui = initUI({
      controls,
      h3dGreeting: document.getElementById('h3dGreeting'),
      h3dClock: document.getElementById('h3dClock'),
      h3dType: document.getElementById('h3dType'),
      h3dDescEl: document.getElementById('h3dDesc'),
      charWraps,
      lens: document.getElementById('lens'),
      lt1: document.getElementById('lt1'),
      lt2: document.getElementById('lt2'),
      ls: document.getElementById('ls'),
      dragHint,
      textNodes,
    });

    const animator = createAnimator({
      scene: sd,
      controls,
      charWraps,
      updateProjection: projection.update,
      resetBtn,
      onFrame: () => (ui as any).updateLens?.(),
    });

    animator.start();
  }
</script>
