<section class="hero hero-landing">
  <!-- Particles -->
  <div class="hero-particles" aria-hidden="true">
    <span class="hero-particle" style="width:3px;height:3px;top:18%;left:14%;opacity:0.1;animation:particleFloat 12s ease-in-out infinite;"></span>
    <span class="hero-particle" style="width:2px;height:2px;top:35%;left:78%;opacity:0.08;animation:particleFloat 15s ease-in-out 1s infinite;"></span>
    <span class="hero-particle" style="width:4px;height:4px;top:55%;left:28%;opacity:0.06;animation:particleFloat 10s ease-in-out 2s infinite;"></span>
    <span class="hero-particle" style="width:2px;height:2px;top:72%;left:62%;opacity:0.1;animation:particleFloat 18s ease-in-out 0.5s infinite;"></span>
    <span class="hero-particle" style="width:3px;height:3px;top:25%;left:48%;opacity:0.07;animation:particleFloat 14s ease-in-out 3s infinite;"></span>
    <span class="hero-particle" style="width:2px;height:2px;top:48%;left:8%;opacity:0.09;animation:particleFloat 16s ease-in-out 1.5s infinite;"></span>
    <span class="hero-particle" style="width:3px;height:3px;top:12%;left:68%;opacity:0.08;animation:particleFloat 11s ease-in-out 2.5s infinite;"></span>
    <span class="hero-particle" style="width:2px;height:2px;top:82%;left:38%;opacity:0.1;animation:particleFloat 13s ease-in-out 0.8s infinite;"></span>
    <span class="hero-particle" style="width:3px;height:3px;top:42%;left:88%;opacity:0.06;animation:particleFloat 17s ease-in-out 4s infinite;"></span>
    <span class="hero-particle" style="width:2px;height:2px;top:65%;left:52%;opacity:0.08;animation:particleFloat 19s ease-in-out 1.2s infinite;"></span>
  </div>

  <!-- Time-aware greeting -->
  <p class="hero-time-greeting hero-line" id="timeGreeting"></p>

  <!-- Identity -->
  <p class="hero-greeting hero-line">HELLO, I'M</p>
  <h1 class="hero-name hero-line">烦恼全無<span class="accent">先生</span></h1>
  <p class="hero-title hero-line" data-typewriter="独立开发者 / 全栈工程师 · 专注效率工具与优雅数字产品">
    <span id="typewriter"></span><span class="typewriter-cursor"></span>
  </p>
  <div class="hero-tags hero-line">
    <span>全栈开发</span>
    <span>独立开发</span>
    <span>效率工具</span>
    <span>开源</span>
  </div>

  <!-- Navigation entries -->
  <div class="hero-nav hero-line">
    <a href="/articles/" class="hero-nav-link">
      <span class="hero-nav-label">文章</span>
      <span class="hero-nav-arrow">→</span>
    </a>
    <a href="/apps/" class="hero-nav-link">
      <span class="hero-nav-label">应用</span>
      <span class="hero-nav-arrow">→</span>
    </a>
    <a href="/about/" class="hero-nav-link">
      <span class="hero-nav-label">关于</span>
      <span class="hero-nav-arrow">→</span>
    </a>
  </div>

  <!-- Clock -->
  <div class="hero-clock hero-line" id="heroClock">
    <span id="clockDisplay">--:--:--</span>
  </div>
</section>
