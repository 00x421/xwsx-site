---
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/articles/', label: '文章' },
  { href: '/apps/', label: '应用' },
  { href: '/about/', label: '关于' },
];
---

<nav class="navbar">
  <a href="/" class="nav-logo"><span class="logo-mark">✦</span> 烦恼全無先生</a>
  <ul class="nav-links">
    {navLinks.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>
