---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  apps: CollectionEntry<'apps'>[];
}

const { apps } = Astro.props;
---

<section class="section" id="apps">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-num">02</span>
      <h2>我的应用</h2>
      <p>自己开发的小工具，欢迎试用反馈</p>
    </div>

    {apps.length > 0 ? (
      <div class="apps-grid">
        {apps.map(app => (
          <a href={`/apps/${app.slug}/`} class="tilt-card app-card">
            <div class="app-top">
              <div class="app-icon">{app.data.icon || '📦'}</div>
              <span class="app-ver">v{app.data.version}</span>
            </div>
            <h3>{app.data.name}</h3>
            <p class="app-desc">{app.data.summary}</p>
            <div class="app-platforms">
              {app.data.platforms.map(p => (
                <span>{p}</span>
              ))}
            </div>
            <div class="app-actions">
              {app.data.downloadUrl && <span class="app-btn primary">下载</span>}
              {app.data.repoUrl && <span class="app-btn">源代码</span>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="text-align:center;color:var(--text-muted);padding:60px 0;">还没有发布的应用，开发中</p>
    )}

    <div class="view-all reveal">
      <a href="/apps/">查看全部应用 &rarr;</a>
    </div>
  </div>
</section>
