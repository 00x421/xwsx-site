---
---

{/* Ambient music player */}
<div class="music-player" id="musicPlayer">
  <button class="player-toggle" id="playerToggle" title="环境音" aria-label="环境音控制">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
    </svg>
  </button>
  <div class="player-panel" id="playerPanel" role="dialog" aria-label="环境音选择">
    <p class="player-label">环境音</p>
    <div class="player-tracks" id="playerTracks">
      <button class="player-track-btn" data-track="rain" aria-label="雨声">
        <span class="playing-bars" style="display:none"><span class="playing-bar"></span><span class="playing-bar"></span><span class="playing-bar"></span></span>
        <span>雨声</span>
      </button>
      <button class="player-track-btn" data-track="ocean" aria-label="海浪">
        <span class="playing-bars" style="display:none"><span class="playing-bar"></span><span class="playing-bar"></span><span class="playing-bar"></span></span>
        <span>海浪</span>
      </button>
      <button class="player-track-btn" data-track="forest" aria-label="森林">
        <span class="playing-bars" style="display:none"><span class="playing-bar"></span><span class="playing-bar"></span><span class="playing-bar"></span></span>
        <span>森林</span>
      </button>
      <button class="player-track-btn" data-track="noise" aria-label="白噪音">
        <span class="playing-bars" style="display:none"><span class="playing-bar"></span><span class="playing-bar"></span><span class="playing-bar"></span></span>
        <span>白噪音</span>
      </button>
    </div>
    <div class="player-volume">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
      <input type="range" id="playerVolume" min="0" max="100" value="65" aria-label="音量" />
    </div>
  </div>
  {/* First-visit hint */}
  <div class="player-hint" id="playerHint">
    <span>试试环境音 →</span>
  </div>
</div>

<script>
  const playerToggle = document.getElementById('playerToggle');
  const playerPanel = document.getElementById('playerPanel');
  const volumeSlider = document.getElementById('playerVolume') as HTMLInputElement;
  const trackBtns = document.querySelectorAll('.player-track-btn');
  const playerHint = document.getElementById('playerHint');

  let audioCtx: AudioContext | null = null;
  let sourceNode: AudioBufferSourceNode | null = null;
  let gainNode: GainNode | null = null;
  let currentTrack: string | null = null;
  let lfoNode: OscillatorNode | null = null;

  interface TrackConfig {
    freq: number; Q: number; vol: number;
    type: BiquadFilterType;
    lfo?: { freq: number; depth: number };
  }

  const trackConfigs: Record<string, TrackConfig> = {
    rain:   { freq: 2000, Q: 0.4, vol: 0.9,  type: 'bandpass' },
    ocean:  { freq: 400,  Q: 0.3, vol: 1.0,  type: 'lowpass', lfo: { freq: 0.08, depth: 0.3 } },
    forest: { freq: 2500, Q: 1.5, vol: 0.6,  type: 'bandpass' },
    noise:  { freq: 8000, Q: 0.3, vol: 0.4,  type: 'lowpass' },
  };

  function getAudioCtx(): AudioContext {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  function createNoiseBuffer(): AudioBuffer {
    const ctx = getAudioCtx();
    const size = ctx.sampleRate * 4;
    const buffer = ctx.createBuffer(2, size, ctx.sampleRate);
    for (let ch = 0; ch < 2; ch++) {
      const data = buffer.getChannelData(ch);
      for (let i = 0; i < size; i++) data[i] = Math.random() * 2 - 1;
    }
    return buffer;
  }

  function stopTrack(): void {
    if (sourceNode) {
      try { sourceNode.stop(); } catch { /* already stopped */ }
      sourceNode.disconnect();
      sourceNode = null;
    }
    if (gainNode) {
      gainNode.disconnect();
      gainNode = null;
    }
    if (lfoNode) {
      try { lfoNode.stop(); } catch { /* already stopped */ }
      lfoNode.disconnect();
      lfoNode = null;
    }
    currentTrack = null;
    playerToggle?.classList.remove('playing');
    trackBtns.forEach(b => {
      b.classList.remove('active');
      const bars = b.querySelector('.playing-bars') as HTMLElement;
      if (bars) bars.style.display = 'none';
    });
  }

  function playTrack(name: string): void {
    stopTrack();
    const ctx = getAudioCtx();
    const cfg = trackConfigs[name];
    if (!cfg) return;

    const buffer = createNoiseBuffer();
    sourceNode = ctx.createBufferSource();
    sourceNode.buffer = buffer;
    sourceNode.loop = true;

    const filter = ctx.createBiquadFilter();
    filter.type = cfg.type;
    filter.frequency.value = cfg.freq;
    filter.Q.value = cfg.Q;

    gainNode = ctx.createGain();
    gainNode.gain.value = cfg.vol * (parseInt(volumeSlider?.value || '40') / 100);

    sourceNode.connect(filter);
    filter.connect(gainNode);
    gainNode.connect(ctx.destination);

    if (cfg.lfo) {
      lfoNode = ctx.createOscillator();
      const lfoGain = ctx.createGain();
      lfoNode.frequency.value = cfg.lfo.freq;
      lfoGain.gain.value = cfg.lfo.depth;
      lfoNode.connect(lfoGain);
      lfoGain.connect(gainNode.gain);
      lfoNode.start();
    }

    sourceNode.start();
    currentTrack = name;
    playerToggle?.classList.add('playing');

    trackBtns.forEach(b => {
      const isActive = b.getAttribute('data-track') === name;
      b.classList.toggle('active', isActive);
      const bars = b.querySelector('.playing-bars') as HTMLElement;
      if (bars) bars.style.display = isActive ? 'flex' : 'none';
    });
  }

  playerToggle?.addEventListener('click', () => {
    const open = playerPanel?.classList.toggle('open');
    if (!open && currentTrack) stopTrack();
  });

  trackBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const track = btn.getAttribute('data-track');
      if (currentTrack === track) {
        stopTrack();
      } else if (track) {
        playTrack(track);
      }
    });
  });

  volumeSlider?.addEventListener('input', () => {
    if (gainNode && currentTrack) {
      const cfg = trackConfigs[currentTrack];
      gainNode.gain.value = cfg.vol * (parseInt(volumeSlider.value) / 100);
    }
  });

  document.addEventListener('click', e => {
    const target = e.target as HTMLElement;
    if (!target.closest('.music-player') && playerPanel?.classList.contains('open')) {
      playerPanel.classList.remove('open');
    }
  });

  // First-visit hint
  if (playerHint && !localStorage.getItem('player-hint-shown')) {
    playerHint.classList.add('visible');
    localStorage.setItem('player-hint-shown', '1');
    setTimeout(() => playerHint.classList.remove('visible'), 3000);
  }
</script>
